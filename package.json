{
  "name": "paddle-sdk",
  "description": "The Paddle.com Node.js SDK",
  "version": "5.0.0",
  "type": "module",
  "exports": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "author": "Valentin Agachi <github-com@agachi.name>",
  "repository": {
    "type": "git",
    "url": "https://github.com/avaly/paddle-sdk"
  },
  "license": "MIT",
  "keywords": [
    "paddle",
    "sdk",
    "api",
    "payments",
    "subscriptions"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "lib/"
  ],
  "scripts": {
    "build": "./build.sh",
    "docs": "typedoc",
    "lint": "eslint . --cache --fix",
    "prepack": "pnpm build",
    "prepare": "husky",
    "pretty": "prettier --ignore-unknown --list-different --write \"**/*\"",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:build": "./tests/build.sh",
    "test:pretty": "prettier --check --ignore-unknown \"**/*\"",
    "test:types": "tsc --noEmit",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@fetch-mock/jest": "0.2.20",
    "@types/jest": "29.5.14",
    "@types/node": "24.12.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "fetch-mock": "12.6.0",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "13.3.0",
    "prettier": "2.8.8",
    "ts-jest": "29.0.5",
    "ts-node": "10.9.2",
    "typescript-eslint": "8.58.0",
    "typedoc": "0.28.18",
    "typescript": "5.9.3",
    "validate-commit-msg": "2.14.0"
  },
  "packageManager": "pnpm@10.33.0"
}
